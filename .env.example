# Blackboard Environment Variables

# ── Required ──────────────────────────────────────────────────────────────────
# Fernet encryption key for credential storage
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-to-a-generated-fernet-key

# ── Infrastructure (optional) ─────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379
# DATA_DIR=/data/sessions

# Note: API keys for LLM providers are configured via the Web UI
# (Config → Model Settings → Set Key). They are stored encrypted
# in config/agents/credentials.enc and never read from environment variables.
